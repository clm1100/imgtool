# npm配置文件 - 加快安装速度和避免卡住

# 使用阿里NPM镜像（中国境内更快）
registry=https://registry.npmmirror.com

# sharp库的二进制镜像
sharp_binary_host_mirror=https://npmmirror.com

# 增加网络超时时间（默认30s，改为120s）
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# 禁用一些不需要的检查，加快速度
audit=false
fund=false

# 并发数设置
maxsockets=50

# 日志级别
loglevel=warn
